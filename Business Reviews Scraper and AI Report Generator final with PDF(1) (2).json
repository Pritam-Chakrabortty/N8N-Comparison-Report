    {
      "parameters": {
        "promptType": "define",
        "text": "=Analyze the following Google Maps reviews and generate a structured business report.\n\nReviews Data:\n{{ JSON.stringify($input.all().map(item => item.json), null, 2) }}\n\nInstructions:\n- Group reviews by placeName.\n- Calculate totalReviews and averageRating using actual ratings.\n- Perform sentiment analysis from review text.\n- Identify top strengths and weaknesses mentioned repeatedly.\n- Provide actionable recommendations.\n- Select one strong positive review and one critical negative review.\n\nReturn ONLY valid JSON in this structure:\n[\n  {\n    \"businessName\": \"\",\n    \"totalReviews\": 0,\n    \"averageRating\": 0,\n    \"sentimentSummary\": \"\",\n    \"keyStrengths\": [],\n    \"keyWeaknesses\": [],\n    \"recommendations\": [],\n    \"topPositiveReview\": \"\",\n    \"topNegativeReview\": \"\"\n  }\n]\nDo not include explanations or markdown.\n",
        "hasOutputParser": true,
        "options": {
          "systemMessage": "You are an expert business analyst specializing in customer review analysis. Your task is to analyze Google Maps reviews and provide actionable insights to help business owners improve their operations, customer satisfaction, and online reputation. Focus on patterns, sentiment trends, and specific actionable recommendations."
        }
      },
